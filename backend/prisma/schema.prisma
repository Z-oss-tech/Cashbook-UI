generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  phone
  google
  password
}

enum RecordType {
  income
  expense
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  username     String?      @unique @db.VarChar(100)
  name         String?      @db.VarChar(120)
  email        String?      @unique @db.VarChar(160)
  phone        String?      @unique @db.VarChar(20)
  passwordHash String?      @db.VarChar(255)
  authProvider AuthProvider @default(password)
  googleId     String?      @unique @db.VarChar(191)
  avatarUrl    String?      @db.VarChar(500)
  createdAt    DateTime     @default(now())
  
  cashbooks    Cashbook[]

  @@map("users")
}

model OtpCode {
  id         String    @id @default(uuid()) @db.Uuid
  phone      String    @db.VarChar(20)
  otpHash    String    @db.VarChar(255)
  expiresAt  DateTime
  verifiedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_codes")
}

model Cashbook {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  name           String   @db.VarChar(150)
  description    String?  @db.Text
  openingBalance Decimal  @default(0.00) @db.Decimal(12, 2)
  currency       String   @default("INR") @db.VarChar(3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isArchived     Boolean  @default(false)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  records Record[]

  @@index([userId])
  @@index([isArchived])
  @@map("cashbooks")
}

model Record {
  id              String     @id @default(uuid()) @db.Uuid
  cashbookId      String     @db.Uuid
  title           String     @db.VarChar(180)
  amount          Decimal    @db.Decimal(12, 2)
  type            RecordType
  category        String?    @db.VarChar(100)
  paymentMethod   String?    @db.VarChar(80)
  note            String?    @db.Text
  attachmentUrl   String?    @db.VarChar(500)
  voiceText       String?    @db.Text
  transactionDate DateTime
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  isDeleted       Boolean    @default(false)

  cashbook Cashbook @relation(fields: [cashbookId], references: [id], onDelete: Cascade)

  @@index([cashbookId])
  @@index([type])
  @@index([transactionDate])
  @@index([isDeleted])
  @@map("records")
}
